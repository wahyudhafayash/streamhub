# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# YOUTUBE_API_KEY: Required to fetch YouTube video and channel data.
# Users configure this via the Secrets panel in the AI Studio UI.
YOUTUBE_API_KEY="MY_YOUTUBE_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

YOUTUBE_HANDLE="loncengelias"
TIKTOK_HANDLE="loncengelias"

NEXT_PUBLIC_YOUTUBE_LINK="https://youtube.com/@loncengelias"
NEXT_PUBLIC_TIKTOK_LINK="https://www.tiktok.com/@loncengelias"
NEXT_PUBLIC_INSTAGRAM_LINK="https://www.instagram.com/loncengelias"
NEXT_PUBLIC_DISCORD_LINK="https://discord.gg/"
NEXT_PUBLIC_SAWERIA_LINK="https://saweria.co/loncengelias"
NEXT_PUBLIC_TAKO_LINK="https://trakteer.id/loncengelias"
